DATABASE_URL=postgresql+asyncpg://user:password@localhost/restos
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ANTHROPIC_API_KEY=your-anthropic-key

# Telegram bot (get token from @BotFather)
BOT_TOKEN_VENUE_1=your-bot-token

# Get these UUIDs from your database:
# SELECT id FROM networks LIMIT 1;
# SELECT id FROM venues WHERE name = 'your-venue-name';
NETWORK_ID=uuid-of-your-network
VENUE_ID_1=uuid-of-venue-for-bot

# Internal shared secret between bot and API (generate with: openssl rand -hex 32)
BOT_API_SECRET=change-this-to-a-random-secret

# Public URL of this deployment (used for Stripe redirect/webhook URLs)
PUBLIC_URL=https://your-domain.com

# Stripe billing (leave empty to disable online payment — /billing shows a "contact support" fallback)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Your email — grants access to /platform/admin (all-tenant overview). Leave empty to disable.
PLATFORM_ADMIN_EMAIL=
